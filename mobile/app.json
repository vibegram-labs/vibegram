{
  "expo": {
    "scheme": "vibe",
    "name": "Vibegram",
    "slug": "vibegram-y2l8y6",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/logo1.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "autolinking": {
      "nativeModulesDir": "./modules",
      "searchPaths": [
        "./node_modules",
        "./modules"
      ]
    },
    "splash": {
      "image": "./assets/logos/logo1.png",
      "resizeMode": "contain",
      "backgroundColor": "#191919"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohammadshayani.vibegram",
      "bitcode": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/logo1.png",
        "backgroundColor": "#191919"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mohammadshayani.vibegram",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/logos/logo1.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Vibe to access your camera to capture moments.",
          "microphonePermission": "Allow Vibe to access your microphone to record video sound.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Vibe to access your photos to share them.",
          "savePhotosPermission": "Allow Vibe to save photos to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-localization",
      "@config-plugins/react-native-webrtc",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21",
            "jvmTarget": "17",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "extraMavenRepos": [
              "https://www.jitpack.io"
            ]
          },
          "ios": {
            "deploymentTarget": "16.0",
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Vibe to access your contacts to connect properly."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Vibe to access your location to share it in chat."
        }
      ],
      "expo-dynamic-app-icon",
      "./plugins/withKotlinJvmTarget",
      "./plugins/withBottomTabs"
    ],
    "extra": {
      "nativeChat": {
        "enabled": true
      },
      "router": {},
      "eas": {
        "projectId": "a28a8e8e-30c7-4e30-b9f6-32c874e94a3b"
      }
    },
    "owner": "mohammadsh3s-organization"
  }
}
