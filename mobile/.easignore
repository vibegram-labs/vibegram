# Keep all mobile/.gitignore rules here too.
# EAS does not read .gitignore when .easignore exists.

# dependencies
node_modules/

# git and server backend
.git/
server_nodejs_old/
server/
client/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# Native folders MUST be included for this project (custom native modules / bare changes)
# Do not ignore ios/ or android/ here.
ios/Pods/
ios/build/
android/.gradle/
android/app/build/
android/build/

# Local logs and debug artifacts
*.log
build_log.txt
yarn_build_log.txt
tsc_output.txt

# Local scratch files
old_bubble.tsx
temp_tool_selector.tsx
app/chat copy.txt
rg
.tools/
*.bak
.easignore.bak

# Editor / local caches / tmp
.idea/
.vscode/
.cache/
tmp/
.tmp/
*.tmp
*.swp
*.swo

# Generated artifacts
*.apk
*.aab
*.ipa
*.dSYM/
android/.cxx/
android/app/.cxx/
android/local.properties

# Wallpaper source files not used by runtime (transparent variants are used)
assets/Wallpapers/animals.PNG
assets/Wallpapers/doodle.PNG
assets/Wallpapers/food.PNG
assets/Wallpapers/music.png
assets/Wallpapers/music 2.png
assets/Wallpapers/music2.PNG
assets/Wallpapers/process_all_wallpapers.py
